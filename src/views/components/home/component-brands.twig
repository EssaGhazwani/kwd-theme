{# BRANDS COMPONENT — KWD Theme #}
<section class="section" aria-labelledby="brands-heading">
  <div class="container">
    <header class="section-header">
      <h2 class="section-title" id="brands-heading">{{ data.settings.title | default(trans('brands')) }}</h2>
    </header>
    <div style="display:flex;flex-wrap:wrap;gap:1rem;justify-content:center;align-items:center;">
      {% for brand in data.brands | default([]) %}
        <a
          href="{{ brand.url }}"
          class="brand-logo"
          aria-label="{{ brand.name }}"
          style="display:flex;align-items:center;justify-content:center;padding:.75rem 1.5rem;border:1px solid var(--color-border);border-radius:var(--radius-md);background:#fff;transition:var(--transition);"
        >
          {% if brand.logo %}
            <img src="{{ brand.logo }}" alt="{{ brand.name }}" height="40" loading="lazy" style="height:40px;object-fit:contain;filter:grayscale(1);transition:var(--transition);">
          {% else %}
            <span style="font-size:.9rem;font-weight:600;color:var(--color-primary);">{{ brand.name }}</span>
          {% endif %}
        </a>
      {% endfor %}
    </div>
  </div>
</section>
