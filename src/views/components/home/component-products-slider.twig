{# PRODUCTS SLIDER — KWD Theme #}
<section class="section" aria-labelledby="products-slider-heading">
  <div class="container">
    <header class="section-header">
      <span class="section-label">{{ data.settings.label | default(trans('featured')) }}</span>
      <h2 class="section-title" id="products-slider-heading">{{ data.settings.title | default(trans('products')) }}</h2>
      {% if data.settings.url %}
        <a href="{{ data.settings.url }}" class="section-link">{{ trans('view_all') }}</a>
      {% endif %}
    </header>
    <div class="products-slider-wrap">
      <div class="products-grid products-grid-4">
        {% for product in data.products | default([]) | slice(0, 8) %}
          {% include 'components/product-card.twig' with { product: product } %}
        {% endfor %}
      </div>
    </div>
  </div>
</section>
