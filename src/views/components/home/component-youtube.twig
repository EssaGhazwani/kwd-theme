{# YOUTUBE COMPONENT — KWD Theme #}
{% if data.settings.video_id %}
<section class="section" aria-label="{{ data.settings.title | default('Video') }}">
  <div class="container" style="max-width:860px;">
    {% if data.settings.title %}
      <h2 class="section-title" style="text-align:center;margin-bottom:1.5rem;">{{ data.settings.title }}</h2>
    {% endif %}
    <div style="position:relative;padding-bottom:56.25%;border-radius:var(--radius-lg);overflow:hidden;">
      <iframe
        src="https://www.youtube-nocookie.com/embed/{{ data.settings.video_id }}"
        title="{{ data.settings.title | default('Video') }}"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
        loading="lazy"
        style="position:absolute;top:0;left:0;width:100%;height:100%;border:0;"
      ></iframe>
    </div>
  </div>
</section>
{% endif %}
