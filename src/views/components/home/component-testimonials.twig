{# TESTIMONIALS — KWD Theme #}
<section class="section" style="background:var(--color-surface);" aria-labelledby="testimonials-heading">
  <div class="container">
    <header class="section-header">
      <h2 class="section-title" id="testimonials-heading">{{ data.settings.title | default(trans('testimonials')) }}</h2>
    </header>
    <div class="grid-3" style="gap:1.5rem;">
      {% for testimonial in data.settings.testimonials | default([]) %}
        <blockquote style="background:#fff;border:1px solid var(--color-border);border-radius:var(--radius-md);padding:1.5rem;position:relative;">
          <div style="color:#fbbf24;margin-bottom:.75rem;font-size:1rem;" aria-hidden="true">
            {% for i in 1..5 %}<i class="sicon-star"></i>{% endfor %}
          </div>
          <p style="color:var(--color-text);line-height:1.75;font-size:.95rem;margin-bottom:1rem;">"{{ testimonial.text }}"</p>
          <footer style="font-size:.85rem;font-weight:600;color:var(--color-primary);">— {{ testimonial.author }}</footer>
        </blockquote>
      {% endfor %}
    </div>
  </div>
</section>
