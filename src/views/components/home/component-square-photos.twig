{# SQUARE PHOTOS — KWD Theme #}
{% if data.settings.images is defined and data.settings.images | length %}
<section class="section">
  <div class="container">
    {% if data.settings.title %}
      <h2 class="section-title" style="margin-bottom:1.5rem;">{{ data.settings.title }}</h2>
    {% endif %}
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:1rem;">
      {% for photo in data.settings.images %}
        <a href="{{ photo.url | default('#') }}" style="display:block;border-radius:var(--radius-md);overflow:hidden;aspect-ratio:1;">
          <img
            src="{{ photo.image }}"
            alt="{{ photo.alt | default(data.settings.title | default('Photo')) }}"
            loading="lazy"
            style="width:100%;height:100%;object-fit:cover;transition:transform .3s ease;"
            onmouseover="this.style.transform='scale(1.05)'"
            onmouseout="this.style.transform='scale(1)'"
          >
        </a>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}
