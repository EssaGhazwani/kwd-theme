              </div>
              <a href="{{ p.url }}" class="btn-add-cart btn btn-primary btn-sm" style="width:100%;display:flex;align-items:center;justify-content:center;gap:.45rem;margin-top:.75rem;">
                <i class="sicon-shopping-bag" aria-hidden="true"></i> {{ trans('add_to_cart') | default('أضف للسلة') }}
              </a>
            </div>
          </article>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{# ═══ 7. REMAINING CMS COMPONENTS ═══ #}
{% for component in page.content %}
  {% if component.type not in ['hero-slider','component-enhanced-slider','component-photos-slider','component-featured-products','component-latest-products'] %}

    {% if component.type == 'component-products-slider' %}
      {% include 'components/home/component-products-slider.twig' with { data: component } %}
    {% elseif component.type == 'component-fixed-products' %}
      {% include 'components/home/component-fixed-products.twig' with { data: component } %}
    {% elseif component.type == 'component-fixed-banner' %}
      {% include 'components/home/component-fixed-banner.twig' with { data: component } %}
    {% elseif component.type == 'component-parallax-background' %}
      {% include 'components/home/component-parallax-background.twig' with { data: component } %}
    {% elseif component.type == 'component-store-features' %}
      {% include 'components/home/component-store-features.twig' with { data: component } %}
    {% elseif component.type in ['component-testimonials','component-random-testimonials'] %}
      {% include 'components/home/component-testimonials.twig' with { data: component } %}
    {% elseif component.type == 'component-brands' %}
      {% include 'components/home/component-brands.twig' with { data: component } %}
    {% elseif component.type == 'component-youtube' %}
      {% include 'components/home/component-youtube.twig' with { data: component } %}
    {% elseif component.type in ['component-square-photos','component-enhanced-square-banners'] %}
      {% include 'components/home/component-enhanced-square-banners.twig' with { data: component } %}
    {% elseif component.type == 'component-main-links' %}
      {% include 'components/home/component-main-links.twig' with { data: component } %}
    {% elseif component.type == 'categories-grid' %}
      {% include 'components/home/categories-grid.twig' with { data: component } %}
    {% elseif component.type == 'trust-badges' %}
      {% include 'components/home/trust-bar.twig' with { data: component } %}
    {% endif %}

  {% endif %}
{% endfor %}

{# ═══ 8. WHY SHOP WITH US ═══ #}
<section class="section" aria-labelledby="why-heading">
  <div class="container">
    <header class="section-header">
      <span class="section-label">لماذا نحن؟</span>
      <h2 class="section-title" id="why-heading">تسوّق بثقة واطمئنان</h2>
      <p class="section-subtitle">مزايا تجعل تجربة التسوق معنا استثنائية في كل مرة</p>
    </header>
    <div class="features-grid">
      {% for feat in demo_features %}
        <div class="feature-card">
          <div class="feature-icon-wrap">
            <i class="{{ feat.icon }} feature-icon" aria-hidden="true"></i>
          </div>
          <h3 class="feature-title">{{ feat.title }}</h3>
          <p class="feature-desc">{{ feat.desc }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{# ═══ 9. CUSTOMER TESTIMONIALS ═══ #}
<section class="section" style="background:var(--color-primary);" aria-labelledby="reviews-heading">
  <div class="container">
    <header class="section-header">
      <span class="section-label" style="color:var(--color-accent);">آراء العملاء</span>
      <h2 class="section-title" id="reviews-heading" style="color:#fff;">ماذا يقول عملاؤنا؟</h2>
      <p class="section-subtitle" style="color:rgba(255,255,255,.65);">آلاف العملاء الراضين يشاركون تجاربهم الحقيقية معنا</p>
    </header>
    <div class="testimonials-grid">
      {% for t in demo_testimonials %}
        <blockquote class="testimonial-card">
          <div class="testimonial-quote" aria-hidden="true">❝</div>
          <p class="testimonial-text">{{ t.text }}</p>
          <footer class="testimonial-author">
            <div class="testimonial-avatar" style="background:{{ t.color }};" aria-hidden="true">
              {{ t.name | slice(0, 1) }}
            </div>
            <div>
              <div class="testimonial-name">{{ t.name }}</div>
              <div class="testimonial-city">{{ t.city }}</div>
            </div>
            <div class="testimonial-stars" aria-label="5 نجوم">★★★★★</div>
          </footer>
        </blockquote>
      {% endfor %}
    </div>
  </div>
</section>

{# ═══ 10. NEWSLETTER ═══ #}
{% if settings.show_newsletter %}
<section class="section newsletter-section" aria-labelledby="newsletter-heading">
  <div class="container" style="max-width:640px;text-align:center;">
    <span class="section-label">اشترك معنا</span>
    <h2 class="section-title" id="newsletter-heading" style="margin-bottom:.75rem;">لا تفوّتك أي عروض!</h2>
    <p style="color:var(--color-text-muted);margin-bottom:1.75rem;line-height:1.7;">
      اشترك في نشرتنا البريدية واحصل على خصم <strong>10%</strong> على أول طلب،
      وكن أول من يعرف عن العروض الحصرية والمجموعات الجديدة.
    </p>
    <salla-newsletter></salla-newsletter>
  </div>
</section>
{% endif %}

{# ═══ 11. BLOG PREVIEW ═══ #}
{% set blog_posts = (page.blog_posts is defined and page.blog_posts | length) ? page.blog_posts : demo_blog %}

<section class="section" style="background:var(--color-surface);" aria-labelledby="blog-home-heading">
  <div class="container">
    <header class="section-header">
      <span class="section-label">{{ trans('blog') | default('المدونة') }}</span>
      <h2 class="section-title" id="blog-home-heading">{{ trans('latest_articles') | default('أحدث المقالات') }}</h2>
      <a href="{{ store.url }}/blog" class="section-link">
        {{ trans('view_all_articles') | default('كل المقالات') }}
        <i class="sicon-arrow-{{ store.language.direction == 'rtl' ? 'left' : 'right' }}" aria-hidden="true"></i>
      </a>
    </header>
    <div class="demo-blog-grid">
      {% for post in blog_posts | slice(0, 3) %}
        {% if post.color is defined %}
          <article class="demo-blog-card" itemscope itemtype="https://schema.org/BlogPosting">
            <div class="demo-blog-thumb" style="background:{{ post.color }};">
              <i class="sicon-edit" style="font-size:2.5rem;color:var(--color-primary);opacity:.25;" aria-hidden="true"></i>
            </div>
            <div class="demo-blog-body">
              <div class="demo-blog-date"><i class="sicon-calendar" aria-hidden="true"></i> {{ post.date }}</div>
              <h3 class="demo-blog-title" itemprop="headline"><a href="{{ post.url }}">{{ post.title }}</a></h3>
              <p class="demo-blog-excerpt" itemprop="description">{{ post.excerpt }}</p>
              <a href="{{ post.url }}" class="demo-blog-link">
                {{ trans('read_more') | default('اقرأ المزيد') }}
                <i class="sicon-arrow-{{ store.language.direction == 'rtl' ? 'left' : 'right' }}" aria-hidden="true"></i>
              </a>
            </div>
          </article>
        {% else %}
          {% include 'components/blog-card.twig' with { post: post } %}
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% endblock %}
