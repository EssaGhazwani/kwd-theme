{# ═══════════════════════════════════════════════
   HOME PAGE — KWD Theme
   SEO: Schema WebPage, ItemList for products
   Page: index.twig
═══════════════════════════════════════════════ #}

{% extends 'layouts/master.twig' %}

{% block extra_head %}
{# HomePage Schema #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": "{{ store.url }}#webpage",
  "url": "{{ store.url }}",
  "name": "{{ store.name }}",
  "isPartOf": { "@type": "WebSite", "url": "{{ store.url }}" },
  "about": { "@type": "Thing", "name": "{{ store.name }}" },
  "description": "{{ settings.seo_default_description }}"
}
</script>
{% endblock %}

{% block content %}

{# ══════════════════════════════════════════════════
   Determine which content types exist in page.content
   so we can fall back gracefully when nothing is added
══════════════════════════════════════════════════ #}
{% set has_hero = false %}
{% for c in page.content %}
  {% if c.type in ['hero-slider','component-enhanced-slider','component-photos-slider'] %}
    {% set has_hero = true %}
  {% endif %}
{% endfor %}

{# ═══ 1. HERO ═══
   Always visible. If the merchant hasn't added a slider component yet,
   show a branded fallback hero using store data. #}
{% if has_hero %}
  {% for component in page.content %}
    {% if component.type == 'hero-slider' %}
      {% include 'components/home/hero-slider.twig' with { data: component } %}
    {% elseif component.type == 'component-photos-slider' %}
      {% include 'components/home/component-photos-slider.twig' with { data: component } %}
    {% elseif component.type == 'component-enhanced-slider' %}
      {% include 'components/home/component-enhanced-slider.twig' with { data: component } %}
    {% endif %}
  {% endfor %}
{% else %}
  {# ── Default hero (no slider configured yet) ── #}
  <section class="hero-slider hero-default" aria-label="{{ store.name }}" style="background:var(--color-primary);min-height:420px;display:flex;align-items:center;justify-content:center;text-align:center;padding:4rem 1rem;">
    <div class="container">
      {% if store.logo %}
        <img src="{{ store.logo }}" alt="{{ store.name }}" style="height:72px;object-fit:contain;margin:0 auto 1.5rem;filter:brightness(0) invert(1);" loading="eager" fetchpriority="high">
      {% endif %}
      <h1 style="color:#fff;font-size:clamp(1.75rem,5vw,3rem);font-weight:700;line-height:1.2;margin-bottom:1rem;">
        {{ store.name }}
      </h1>
      {% if settings.seo_default_description %}
        <p style="color:rgba(255,255,255,.85);font-size:1.1rem;max-width:560px;margin:0 auto 2rem;line-height:1.7;">
          {{ settings.seo_default_description }}
        </p>
      {% endif %}
      <a href="{{ store.url }}/products" class="btn btn-accent btn-lg" style="font-size:1.05rem;padding:.9rem 2.5rem;">
        {{ trans('start_shopping') }}
      </a>
    </div>
  </section>
{% endif %}

{# ═══ 2. TRUST BAR — always visible ═══ #}
{% include 'components/home/trust-bar.twig' %}

{# ═══ 3. CATEGORIES GRID — always visible if categories exist ═══ #}
{% if store.categories is defined and store.categories | length %}
  {% include 'components/home/categories-grid.twig' %}
{% endif %}

{# ═══ 4. ALL OTHER PAGE BUILDER COMPONENTS ═══ #}
{% for component in page.content %}
  {% if component.type == 'component-featured-products' %}
    {% include 'components/home/component-featured-products.twig' with { data: component } %}

  {% elseif component.type == 'component-products-slider' %}
    {% include 'components/home/component-products-slider.twig' with { data: component } %}

  {% elseif component.type == 'component-latest-products' %}
    {% include 'components/home/component-latest-products.twig' with { data: component } %}

  {% elseif component.type == 'component-fixed-products' %}
    {% include 'components/home/component-fixed-products.twig' with { data: component } %}

  {% elseif component.type == 'component-fixed-banner' %}
    {% include 'components/home/component-fixed-banner.twig' with { data: component } %}

  {% elseif component.type == 'component-parallax-background' %}
    {% include 'components/home/component-parallax-background.twig' with { data: component } %}

  {% elseif component.type == 'component-store-features' %}
    {% include 'components/home/component-store-features.twig' with { data: component } %}

  {% elseif component.type in ['component-testimonials','component-random-testimonials'] %}
    {% include 'components/home/component-testimonials.twig' with { data: component } %}

  {% elseif component.type == 'component-brands' %}
    {% include 'components/home/component-brands.twig' with { data: component } %}

  {% elseif component.type == 'component-youtube' %}
    {% include 'components/home/component-youtube.twig' with { data: component } %}

  {% elseif component.type in ['component-square-photos','component-enhanced-square-banners'] %}
    {% include 'components/home/component-enhanced-square-banners.twig' with { data: component } %}

  {% elseif component.type == 'component-main-links' %}
    {% include 'components/home/component-main-links.twig' with { data: component } %}

  {% elseif component.type == 'categories-grid' %}
    {% include 'components/home/categories-grid.twig' with { data: component } %}

  {% elseif component.type == 'trust-badges' %}
    {% include 'components/home/trust-bar.twig' with { data: component } %}
  {% endif %}
{% endfor %}

{# ═══ 5. RECENT BLOG POSTS ═══ #}
{% if page.blog_posts is defined and page.blog_posts | length %}
<section class="section blog-preview-section" aria-labelledby="blog-section-title">
  <div class="container">
    <header class="section-header">
      <span class="section-label">{{ trans('blog') }}</span>
      <h2 class="section-title" id="blog-section-title">{{ trans('latest_articles') }}</h2>
      <a href="{{ store.url }}/blog" class="section-link">
        {{ trans('view_all_articles') }} <i class="sicon-arrow-{{ store.language.direction == 'rtl' ? 'left' : 'right' }}" aria-hidden="true"></i>
      </a>
    </header>
    <div class="blog-grid">
      {% for post in page.blog_posts | slice(0, 3) %}
        {% include 'components/blog-card.twig' with { post: post } %}
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

{% endblock %}
