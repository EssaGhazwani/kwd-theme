{# ═══ 1. HERO ═══ #}
{% set has_hero = false %}
{% for c in page.content %}
  {% if c.type in ['hero-slider','component-enhanced-slider','component-photos-slider'] %}
    {% set has_hero = true %}
  {% endif %}
{% endfor %}

{% if has_hero %}
  {% for component in page.content %}
    {% if component.type == 'hero-slider' %}
      {% include 'components/home/hero-slider.twig' with { data: component } %}
    {% elseif component.type == 'component-photos-slider' %}
      {% include 'components/home/component-photos-slider.twig' with { data: component } %}
    {% elseif component.type == 'component-enhanced-slider' %}
      {% include 'components/home/component-enhanced-slider.twig' with { data: component } %}
    {% endif %}
  {% endfor %}
{% else %}
  {# ── Beautiful 3-slide demo hero ── #}
  <section class="hero-slider" data-auto="true" aria-label="{{ store.name }}">

    <article class="hero-slide active"
      style="min-height:540px;background:linear-gradient(135deg,#1a1a2e 0%,#16213e 55%,#0f3460 100%);">
      <div aria-hidden="true" style="position:absolute;inset-inline-end:-60px;top:50%;transform:translateY(-50%);width:480px;height:480px;border-radius:50%;background:rgba(233,69,96,.09);"></div>
      <div aria-hidden="true" style="position:absolute;inset-inline-end:80px;top:50%;transform:translateY(-50%);width:280px;height:280px;border-radius:50%;background:rgba(233,69,96,.13);"></div>
      <div class="container" style="position:relative;z-index:2;">
        <div class="hero-content">
          <div class="section-label" style="margin-bottom:.9rem;">{{ store.name }} — مجموعة ٢٠٢٦</div>
          <h1 class="hero-title">
            اكتشف تشكيلتنا<br>
            <span style="color:var(--color-accent);">الحصرية الجديدة</span>
          </h1>
          <p class="hero-subtitle">منتجات فاخرة بأسعار مناسبة — شحن مجاني على الطلبات فوق 200 ر.س</p>
          <div style="display:flex;gap:1rem;flex-wrap:wrap;align-items:center;">
            <a href="{{ store.url }}/products" class="hero-cta">
              تسوّق الآن <i class="sicon-arrow-{{ store.language.direction == 'rtl' ? 'left' : 'right' }}" aria-hidden="true"></i>
            </a>
            <a href="{{ store.url }}/products?sort=newest" style="color:rgba(255,255,255,.8);font-size:.95rem;border-bottom:1px solid rgba(255,255,255,.3);padding-bottom:2px;">أحدث الوصول</a>
          </div>
        </div>
      </div>
    </article>

    <article class="hero-slide"
      style="min-height:540px;background:linear-gradient(135deg,#e94560 0%,#c73652 40%,#0f3460 100%);">
      <div class="container" style="position:relative;z-index:2;">
        <div class="hero-content">
          <div class="section-label" style="margin-bottom:.9rem;color:rgba(255,255,255,.8);">عروض حصرية</div>
          <h1 class="hero-title">خصومات تصل إلى<br><span style="font-size:1.4em;line-height:1;">50%</span></h1>
          <p class="hero-subtitle">لا تفوّت أفضل الصفقات على منتجاتنا المختارة — العرض لفترة محدودة!</p>
          <a href="{{ store.url }}/products?sort=sale" class="hero-cta" style="background:#fff;color:var(--color-accent);">
            تصفّح العروض <i class="sicon-arrow-{{ store.language.direction == 'rtl' ? 'left' : 'right' }}" aria-hidden="true"></i>
          </a>
        </div>
      </div>
    </article>

    <article class="hero-slide"
      style="min-height:540px;background:linear-gradient(135deg,#0f3460 0%,#1a1a2e 100%);">
      <div class="container" style="position:relative;z-index:2;">
        <div class="hero-content">
          <div class="section-label" style="margin-bottom:.9rem;">ضمان الجودة</div>
          <h1 class="hero-title">منتجات أصلية<br><span style="color:var(--color-accent);">بضمان كامل</span></h1>
          <p class="hero-subtitle">جميع منتجاتنا مضمونة ١٠٠٪ أصلية مع خدمة عملاء على مدار الساعة</p>
          <a href="{{ store.url }}/products" class="hero-cta">
            اكتشف المزيد <i class="sicon-arrow-{{ store.language.direction == 'rtl' ? 'left' : 'right' }}" aria-hidden="true"></i>
          </a>
        </div>
      </div>
    </article>

    <button class="slider-arrow slider-arrow-prev" aria-label="السابق">
      <i class="sicon-chevron-{{ store.language.direction == 'rtl' ? 'right' : 'left' }}" aria-hidden="true"></i>
    </button>
    <button class="slider-arrow slider-arrow-next" aria-label="التالي">
      <i class="sicon-chevron-{{ store.language.direction == 'rtl' ? 'left' : 'right' }}" aria-hidden="true"></i>
    </button>
    <div class="slider-controls" role="tablist">
      <button class="slider-dot active" role="tab" aria-selected="true"  aria-label="١"></button>
      <button class="slider-dot"        role="tab" aria-selected="false" aria-label="٢"></button>
      <button class="slider-dot"        role="tab" aria-selected="false" aria-label="٣"></button>
    </div>
  </section>
{% endif %}

{# ═══ 2. TRUST BAR — always visible ═══ #}
{% include 'components/home/trust-bar.twig' %}

{# ═══ 3. CATEGORIES GRID ═══ #}
<section class="section section-sm" aria-labelledby="cats-heading">
  <div class="container">
    <header class="section-header">
      <span class="section-label">{{ trans('browse') | default('تصفّح') }}</span>
      <h2 class="section-title" id="cats-heading">{{ trans('shop_by_category') | default('تسوّق حسب الفئة') }}</h2>
    </header>
    {% set cats = (store.categories is defined and store.categories | length) ? store.categories | slice(0,6) : demo_categories %}
    <div class="cats-home-grid">
      {% for cat in cats %}
        <a href="{{ cat.url | default(store.url ~ '/categories') }}"
          class="cat-home-card"
          style="background:{{ cat.color | default('#f5f5f5') }};"
          aria-label="{{ cat.name }}">
          {% if cat.image is defined and cat.image %}
            <img src="{{ cat.image }}" alt="{{ cat.name }}" style="width:56px;height:56px;object-fit:cover;border-radius:50%;margin:0 auto .75rem;" loading="lazy">
          {% else %}
            <div class="cat-home-icon">
              <i class="{{ cat.icon | default('sicon-tag') }}" style="color:var(--color-primary);"></i>
            </div>
          {% endif %}
          <div class="cat-home-name">{{ cat.name }}</div>
          {% set cnt = cat.count | default(cat.products_count | default(null)) %}
          {% if cnt %}<div class="cat-home-count">{{ cnt }} منتج</div>{% endif %}
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{# ═══ 4. FEATURED PRODUCTS ═══ #}
{% set feat_comp = null %}
{% for c in page.content %}
  {% if c.type == 'component-featured-products' %}{% set feat_comp = c %}{% endif %}
{% endfor %}

<section class="section" aria-labelledby="featured-heading">
  <div class="container">
    <header class="section-header">
      <span class="section-label">{{ trans('featured') | default('مختارة') }}</span>
      <h2 class="section-title" id="featured-heading">
        {{ feat_comp.settings.title | default(trans('featured_products') | default('المنتجات المميزة')) }}
      </h2>
      <p class="section-subtitle">{{ feat_comp.settings.subtitle | default('اختارها فريقنا خصيصًا بناءً على أعلى تقييمات العملاء') }}</p>
      <a href="{{ store.url }}/products" class="section-link">
        {{ trans('view_all') | default('عرض الكل') }}
        <i class="sicon-arrow-{{ store.language.direction == 'rtl' ? 'left' : 'right' }}" aria-hidden="true"></i>
      </a>
    </header>

    {% set has_real_featured = feat_comp is not null and feat_comp.products is defined and feat_comp.products | length %}
    {% set fp = has_real_featured ? feat_comp.products : demo_products %}

    <div class="products-grid products-grid-4">
      {% for p in fp | slice(0, 8) %}
        {% if has_real_featured %}
          {% include 'components/product-card.twig' with { product: p } %}
        {% else %}
          <article class="product-card" itemscope itemtype="https://schema.org/Product">
            <div class="product-thumb">
              <a href="{{ p.url }}" itemprop="url" aria-label="{{ p.name }}">
                <img src="{{ p.thumb }}" alt="{{ p.name }}" width="400" height="400" loading="lazy" itemprop="image">
              </a>
              <div class="product-badges">
                {% if p.sale_price %}<span class="badge-pill badge-sale">{{ p.badge | default('خصم') }}</span>
                {% elseif p.badge %}<span class="badge-pill badge-new">{{ p.badge }}</span>{% endif %}
                {% if p.is_hot %}<span class="badge-pill badge-hot">الأكثر مبيعًا</span>{% endif %}
              </div>
              <div class="product-actions">
                <button class="product-action-btn" aria-label="أضف للمفضلة"><i class="sicon-heart" aria-hidden="true"></i></button>
                <a href="{{ p.url }}" class="product-action-btn" aria-label="عرض سريع: {{ p.name }}"><i class="sicon-eye" aria-hidden="true"></i></a>
              </div>
            </div>
            <div class="product-info">
              <h3 class="product-name" itemprop="name"><a href="{{ p.url }}">{{ p.name }}</a></h3>
              <div class="product-rating" aria-label="5 نجوم">
                <div class="stars"><i class="sicon-star" aria-hidden="true"></i><i class="sicon-star" aria-hidden="true"></i><i class="sicon-star" aria-hidden="true"></i><i class="sicon-star" aria-hidden="true"></i><i class="sicon-star" aria-hidden="true"></i></div>
                <span class="rating-count">(١٢٤)</span>
              </div>
              <div class="product-price" itemprop="offers" itemscope itemtype="https://schema.org/Offer">
                <meta itemprop="priceCurrency" content="{{ store.currency.code | default('SAR') }}">
                {% if p.sale_price %}
                  <span class="price-current" itemprop="price" content="{{ p.sale_price }}">{{ p.sale_price }} ر.س</span>
                  <span class="price-old">{{ p.price }} ر.س</span>
                {% else %}
                  <span class="price-current" itemprop="price" content="{{ p.price }}">{{ p.price }} ر.س</span>
                {% endif %}
              </div>
              <a href="{{ p.url }}" class="btn-add-cart btn btn-primary btn-sm"
                style="width:100%;display:flex;align-items:center;justify-content:center;gap:.45rem;margin-top:.75rem;">
                <i class="sicon-shopping-bag" aria-hidden="true"></i>
                {{ trans('add_to_cart') | default('أضف للسلة') }}
              </a>
            </div>
          </article>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

