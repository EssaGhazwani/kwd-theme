{# ═══════════════════════════════════════════════
   HOME PAGE — KWD Theme
   kwdstore.com | Salla Twilight Engine
   SEO: Schema WebPage + ItemList
   All sections filled — demo data fallback when
   store is empty (great for theme preview)
═══════════════════════════════════════════════ #}

{% extends 'layouts/master.twig' %}

{% block extra_head %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": "{{ store.url }}#webpage",
  "url": "{{ store.url }}",
  "name": "{{ store.name }}",
  "isPartOf": { "@type": "WebSite", "url": "{{ store.url }}" },
  "description": "{{ settings.seo_default_description }}"
}
</script>
{% endblock %}

{% block content %}

