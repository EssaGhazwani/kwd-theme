{# ═══════════════════════════════════════════════
   SINGLE BLOG POST PAGE — KWD Theme
   SEO: Article Schema, Author, DatePublished
═══════════════════════════════════════════════ #}

{% extends 'layouts/master.twig' %}

{% block extra_head %}
<meta property="og:type" content="article">
<meta property="article:published_time" content="{{ post.created_at }}">
{% if post.tags is defined %}
  {% for tag in post.tags %}
    <meta property="article:tag" content="{{ tag }}">
  {% endfor %}
{% endif %}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": "{{ post.title | e('js') }}",
  "url": "{{ post.url }}",
  "datePublished": "{{ post.created_at }}",
  "dateModified": "{{ post.updated_at | default(post.created_at) }}",
  "description": "{{ post.excerpt | striptags | truncate(200) | e('js') }}",
  "image": "{{ post.image.url | default(settings.seo_og_image | asset_url) }}",
  "author": {
    "@type": "Organization",
    "name": "{{ store.name }}"
  },
  "publisher": {
    "@type": "Organization",
    "name": "{{ store.name }}",
    "logo": { "@type": "ImageObject", "url": "{{ store.logo }}" }
  },
  "isPartOf": { "@type": "Blog", "name": "{{ store.name }} Blog", "url": "{{ store.url }}/blog" }
}
</script>
{% endblock %}

{% block content %}
<article class="section" itemscope itemtype="https://schema.org/BlogPosting">

  <div class="container" style="max-width:860px;">

    {# Header #}
    <header style="margin-bottom:2rem;">
      {% if post.tags is defined and post.tags | length %}
        <div style="margin-bottom:.75rem;">
          {% for tag in post.tags %}
            <span class="blog-tag">{{ tag }}</span>
          {% endfor %}
        </div>
      {% endif %}
      <h1 style="font-size:clamp(1.5rem,4vw,2.25rem);font-weight:700;color:var(--color-primary);line-height:1.25;margin-bottom:1rem;" itemprop="headline">
        {{ post.title }}
      </h1>
      <div style="display:flex;align-items:center;gap:1rem;font-size:.85rem;color:var(--color-text-muted);">
        <span><i class="sicon-calendar" aria-hidden="true"></i> <time itemprop="datePublished" datetime="{{ post.created_at }}">{{ post.created_at | date('d F Y') }}</time></span>
        {% if post.reading_time is defined %}
          <span><i class="sicon-clock" aria-hidden="true"></i> {{ post.reading_time }} {{ trans('min_read') }}</span>
        {% endif %}
      </div>
    </header>

    {# Feature image #}
    {% if post.image is defined and post.image.url %}
      <figure style="margin-bottom:2rem;border-radius:var(--radius-lg);overflow:hidden;">
        <img
          src="{{ post.image.url }}"
          alt="{{ post.image.alt | default(post.title) }}"
          width="860"
          height="430"
          loading="eager"
          fetchpriority="high"
          style="width:100%;object-fit:cover;"
          itemprop="image"
        >
      </figure>
    {% endif %}

    {# Content #}
    <div
      class="prose"
      style="line-height:1.9;font-size:1.05rem;color:var(--color-text);"
      itemprop="articleBody"
    >
      {{ post.content | raw }}
    </div>

    {# Share #}
    <div style="margin-top:2rem;padding-top:1.5rem;border-top:1px solid var(--color-border);">
      <salla-social-share url="{{ post.url }}" title="{{ post.title }}"></salla-social-share>
    </div>

  </div>

</article>

{# Related posts #}
{% if related_posts is defined and related_posts | length %}
  <section class="section" style="background:var(--color-surface);border-top:1px solid var(--color-border);">
    <div class="container">
      <h2 class="section-title" style="margin-bottom:2rem;">{{ trans('related_posts') }}</h2>
      <div class="blog-grid">
        {% for rp in related_posts | slice(0, 3) %}
          {% include 'components/blog-card.twig' with { post: rp } %}
        {% endfor %}
      </div>
    </div>
  </section>
{% endif %}

{% endblock %}
