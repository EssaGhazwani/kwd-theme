{# ═══════════════════════════════════════════════
   BLOG LISTING PAGE — KWD Theme
   SEO: Blog Schema, ItemList
═══════════════════════════════════════════════ #}

{% extends 'layouts/master.twig' %}

{% block extra_head %}
{% if page.prev_url %}<link rel="prev" href="{{ page.prev_url }}">{% endif %}
{% if page.next_url %}<link rel="next" href="{{ page.next_url }}">{% endif %}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "{{ store.name }} Blog",
  "url": "{{ page.url }}",
  "publisher": { "@type": "Organization", "name": "{{ store.name }}", "logo": "{{ store.logo }}" }
}
</script>
{% endblock %}

{% block content %}
<div class="section">
  <div class="container">

    <header class="section-header" style="margin-bottom:2.5rem;">
      <span class="section-label">{{ trans('knowledge') }}</span>
      <h1 class="section-title">{{ page.title | default(trans('blog')) }}</h1>
      {% if page.description %}
        <p class="section-subtitle">{{ page.description }}</p>
      {% endif %}
    </header>

    {% if posts is defined and posts | length %}
      <div class="blog-grid">
        {% for post in posts %}
          {% include 'components/blog-card.twig' with { post: post } %}
        {% endfor %}
      </div>

      {% if page.pages > 1 %}
        {% include 'components/pagination.twig' %}
      {% endif %}

    {% else %}
      <div class="text-center" style="padding:3rem 0;">
        <p class="text-muted">{{ trans('no_posts') }}</p>
      </div>
    {% endif %}

  </div>
</div>
{% endblock %}
