{# ORDERS LIST — KWD Theme #}

{% extends 'layouts/master.twig' %}

{% block extra_head %}
<meta name="robots" content="noindex, nofollow">
{% endblock %}

{% block content %}
<div class="section">
  <div class="container">
    <h1 style="font-size:1.25rem;font-weight:700;color:var(--color-primary);margin-bottom:1.5rem;">
      {{ trans('my_orders') }}
    </h1>

    {% if orders is defined and orders | length %}
      <div style="border:1px solid var(--color-border);border-radius:var(--radius-md);overflow:hidden;">
        <table style="width:100%;border-collapse:collapse;font-size:.9rem;">
          <thead style="background:var(--color-surface);">
            <tr>
              <th style="padding:.85rem 1rem;text-align:start;font-weight:600;color:var(--color-primary);">{{ trans('order_number') }}</th>
              <th style="padding:.85rem 1rem;text-align:start;font-weight:600;color:var(--color-primary);">{{ trans('order_date') }}</th>
              <th style="padding:.85rem 1rem;text-align:start;font-weight:600;color:var(--color-primary);">{{ trans('status') }}</th>
              <th style="padding:.85rem 1rem;text-align:start;font-weight:600;color:var(--color-primary);">{{ trans('total') }}</th>
              <th style="padding:.85rem 1rem;text-align:start;font-weight:600;color:var(--color-primary);">{{ trans('actions') }}</th>
            </tr>
          </thead>
          <tbody>
            {% for order in orders %}
              <tr style="border-top:1px solid var(--color-border);">
                <td style="padding:.85rem 1rem;">#{{ order.reference_id }}</td>
                <td style="padding:.85rem 1rem;color:var(--color-text-muted);">{{ order.date | date('d/m/Y') }}</td>
                <td style="padding:.85rem 1rem;">
                  <span style="display:inline-block;padding:.25rem .65rem;border-radius:20px;font-size:.78rem;font-weight:600;background:rgba(var(--color-accent-rgb),.12);color:var(--color-accent);">
                    {{ order.status }}
                  </span>
                </td>
                <td style="padding:.85rem 1rem;font-weight:600;color:var(--color-primary);">{{ order.total | money }}</td>
                <td style="padding:.85rem 1rem;">
                  <a href="{{ store.url }}/orders/{{ order.id }}" class="btn btn-outline btn-sm">{{ trans('view') }}</a>
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>

      {% if page.pages > 1 %}{% include 'components/pagination.twig' %}{% endif %}

    {% else %}
      <div class="text-center" style="padding:4rem 0;">
        <i class="sicon-package" style="font-size:3.5rem;color:var(--color-border);"></i>
        <p style="color:var(--color-text-muted);margin-top:1rem;">{{ trans('no_orders') }}</p>
        <a href="{{ store.url }}/products" class="btn btn-accent" style="margin-top:1.25rem;">{{ trans('start_shopping') }}</a>
      </div>
    {% endif %}

  </div>
</div>
{% endblock %}
